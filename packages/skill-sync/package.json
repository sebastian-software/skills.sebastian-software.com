{
  "name": "skill-sync",
  "version": "0.0.0-alpha.0",
  "description": "Synchronize shared agent skills for Codex and Agents",
  "keywords": [
    "agents",
    "cli",
    "codex",
    "skills",
    "sync",
    "typescript"
  ],
  "license": "MIT",
  "author": "Sebastian Software",
  "bin": {
    "skill-sync": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
